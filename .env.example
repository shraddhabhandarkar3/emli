# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=emli
POSTGRES_PASSWORD=emli
POSTGRES_DB=emli
POSTGRES_PORT=5432

# Full connection URL used by SQLAlchemy / Alembic
DATABASE_URL=postgresql://emli:emli@localhost:5432/emli

# ──────────────────────────────────────────────────────────────────────────────
# Gmail OAuth
# ──────────────────────────────────────────────────────────────────────────────
# Rename your downloaded Google credentials file to client_secret.json
GOOGLE_CREDENTIALS_PATH=client_secret.json
# Where the OAuth token is stored after first run (gitignored)
GOOGLE_TOKEN_PATH=token/token.json
# Where the Gmail historyId cursor is stored between runs (gitignored)
GOOGLE_STATE_PATH=token/gmail_state.json
# How many days back to fetch on the very first run
GMAIL_FETCH_DAYS=30

# ──────────────────────────────────────────────────────────────────────────────
# Notion
# ──────────────────────────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ──────────────────────────────────────────────────────────────────────────────
# LLM Classifier
# Choose ONE provider: "ollama" (local, free) or "api" (external, better quality)
# ──────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama

# ── Option A: Ollama (local, free, no API key needed) ────────────────────────
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434   # use http://ollama:11434 inside Docker

# ── Option B: External API (better quality, requires API key) ─────────────────
# Recommended: Groq — free tier, fast, reliable (https://console.groq.com)
#   API_BASE_URL=https://api.groq.com/openai/v1
#   API_MODEL=llama-3.3-70b-versatile
#   LLM_TIMEOUT=30
#
# NVIDIA NIM — free tier, slower (https://build.nvidia.com)
#   API_BASE_URL=https://integrate.api.nvidia.com/v1
#   API_MODEL=meta/llama-3.1-8b-instruct
#   LLM_TIMEOUT=120
#
# OpenAI — paid, fastest (https://platform.openai.com)
#   API_BASE_URL=   # leave blank, uses OpenAI default
#   API_MODEL=gpt-4o-mini
#   LLM_TIMEOUT=30
API_BASE_URL=https://api.groq.com/openai/v1
API_KEY=
API_MODEL=llama-3.3-70b-versatile

# API request timeout in seconds. Increase for slow providers (NVIDIA NIM: 120).
LLM_TIMEOUT=60

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Pause for LLM_PAUSE_SECONDS after every LLM_BATCH_SIZE LLM calls.
# Set LLM_BATCH_SIZE=0 to disable pausing (for high-RPM paid APIs).
LLM_BATCH_SIZE=20
LLM_PAUSE_SECONDS=60

# ──────────────────────────────────────────────────────────────────────────────
# Timezone (used for date display in Notion)
# ──────────────────────────────────────────────────────────────────────────────
TIMEZONE=America/Los_Angeles

# ──────────────────────────────────────────────────────────────────────────────
# Schedule (only used by `make scheduler` continuous loop)
# ──────────────────────────────────────────────────────────────────────────────
FETCH_INTERVAL_MINUTES=15
