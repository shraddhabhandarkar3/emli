# ──────────────────────────────────────────────
# PostgreSQL (local Docker dev)
# ──────────────────────────────────────────────
POSTGRES_USER=emli
POSTGRES_PASSWORD=emli
POSTGRES_DB=emli
POSTGRES_PORT=5432

# Full connection URL used by SQLAlchemy / Alembic
DATABASE_URL=postgresql://emli:emli@localhost:5432/emli

# ──────────────────────────────────────────────
# Gmail (Ticket 1)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Notion (Ticket 4)
# ──────────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ──────────────────────────────────────────────
# Ollama (Ticket 2)
# ──────────────────────────────────────────────
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# ──────────────────────────────────────────────
# Schedule
# ──────────────────────────────────────────────
FETCH_INTERVAL_MINUTES=15
SYNC_INTERVAL_MINUTES=60
